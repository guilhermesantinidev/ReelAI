# GROQ API (IA - Grátis)
# Pegue em: https://console.groq.com/keys
NEXT_PUBLIC_GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxx

# FIREBASE (Banco de Dados - Grátis)
# Pegue em: https://firebase.google.com → Seu projeto → Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=seu-projeto-xxxxx
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# STRIPE (Pagamentos - Grátis até vender)
# Pegue em: https://dashboard.stripe.com → Developers → API Keys
NEXT_PUBLIC_STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxx

# APP CONFIG
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# INSTRUÇÕES:
# 1. Renomeie este arquivo para .env.local
# 2. Preencha com suas chaves reais
# 3. NUNCA faça commit do .env.local com chaves reais!
# 4. O arquivo .env.local já está em .gitignore (seguro)
